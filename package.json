{
  "name": "ragbot-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "register:commands": "tsx scripts/register-commands.ts",
    "d1:migrate:local": "wrangler d1 execute ragbot --local --file=./schema.sql",
    "d1:migrate:remote": "wrangler d1 execute ragbot --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.13.2"
  },
  "dependencies": {
    "discord-api-types": "^0.38.49",
    "discord.js": "^14.26.4",
    "tweetnacl": "^1.0.3"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
