{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@platy/sdk": ["infra/sdk/ts/src/index.ts"],
      "@platy/web": ["infra/sdk/web/src/index.ts"]
    }
  },
  "include": [
    "infra/sdk/ts/src/**/*.ts",
    "infra/applications/*/worker/src/**/*.ts",
    "infra/applications/ragbot/worker/scripts/**/*.ts",
    "infra/applications/**/service/**/*.ts",
    "infra/applications/**/targets/**/*.ts",
    "infra/applications/discovery/graphql/**/*.ts"
  ]
}