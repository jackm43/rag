{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "infra/sdk/ts/src/**/*.ts",
    "infra/gateway/src/**/*.ts",
    "infra/deploy/src/**/*.ts",
    "infra/applications/**/server/**/*.ts"
  ]
}