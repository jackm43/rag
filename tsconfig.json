{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "infra/ragbot/src/**/*.ts",
    "infra/ragbot/scripts/**/*.ts",
    "infra/sdk/ts/src/**/*.ts",
    "infra/gateway/src/**/*.ts",
    "infra/deploy/src/**/*.ts",
    "infra/aigateway/src/**/*.ts",
    "infra/web/src/worker.ts",
    "infra/applications/**/server/**/*.ts",
    "infra/applications/**/service/**/*.ts"
  ]
}