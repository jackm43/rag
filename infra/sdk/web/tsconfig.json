{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@platy/web": ["src/index.ts"],
      "@platy/sdk": ["../ts/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../applications/*/web/**/*.ts"]
}
