{
  "name": "deploy",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "deploy.jsmunro.me",
      "custom_domain": true
    }
  ],
  "vars": {
    "AUTH_GATEWAY_URL": "https://auth-gateway.jsmunro.me",
    "CLOUDFLARE_ENDPOINT": "https://cloudflare.jsmunro.me"
  },
  "services": [
    {
      "binding": "AUTH_GATEWAY",
      "service": "auth-gateway"
    },
    {
      "binding": "CLOUDFLARE",
      "service": "cloudflare"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
,
  "secrets_store_secrets": [
  {
    "binding": "SERVICE_CLIENT_SECRET",
    "store_id": "2bca8b5b9f7a46999c37ff8eafbf7ba3",
    "secret_name": "platy-deploy-service-client-secret"
  }
]
}